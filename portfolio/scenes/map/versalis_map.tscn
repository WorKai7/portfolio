theme_override_font_sizes/font_size = 20
text = "Versalis est une entreprise qui produit de l’éthylène grâce à un vapocraqueur qui nécessite une surveillance humaine permanente.

Des salariés sont alors postés le matin, le soir ou la nuit et ont donc besoin d’effectuer des roulements selon un planning.

Mon application devait alors établir ces plannings en prenant en compte les absences, maladies, remplacements etc…"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 2

